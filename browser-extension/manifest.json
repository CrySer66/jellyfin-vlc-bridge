{
  "manifest_version": 3,
  "name": "Jellyfin VLC Bridge",
  "short_name": "Jellyfin VLC",
  "version": "1.5.0",
  "key": "",
  "description": "Prépare et lance les films, séries et collections Jellyfin dans VLC.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["nativeMessaging"],
  "action": {
    "default_title": "Jellyfin VLC Bridge",
    "default_popup": "popup.html"
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "http://*/web/*",
        "https://*/web/*",
        "http://*/*/web/*",
        "https://*/*/web/*"
      ],
      "js": ["shared.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
