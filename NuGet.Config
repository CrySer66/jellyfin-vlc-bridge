<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Le code n'utilise aucun paquet tiers. La source officielle sert uniquement
       à récupérer les composants Microsoft nécessaires au paquet autonome. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
